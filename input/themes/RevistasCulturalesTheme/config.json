{
    "name": "RevistasCulturalesTheme",
    "version": "1.0.0.0",
    "author": "Sergio Rodríguez Gómez",
    "renderer": {
        "relatedPostsNumber": 3,
        "renderRelatedPosts": true,
        "renderSimilarPosts": false,
        "renderPrevNextPosts": true,
        "createContentStructure": true,
        "includeFeaturedInPosts": true,
        "tagsIncludeFeaturedInPosts": true,
        "authorsIncludeFeaturedInPosts": true,
        "featuredPostsNumber": 0,
        "tagsFeaturedPostsNumber": 0,
        "authorsFeaturedPostsNumber": 0,
        "createTagPages": true,
        "createAuthorPages": true,
        "createTagsList": true,
        "create404page": true,
        "createSearchPage": true,
        "customHTML": {
            "beforePost": "Before every post",
            "afterPost": "After every post"
        }
    },
    "supportedFeatures": {
        "blockEditor": true,
        "tagsList": true,
        "tagPages": true,
        "tagImages": true,
        "authorPages": true,
        "authorImages": true,
        "searchPage": true,
        "errorPage": true,
        "customSearch": true, 
        "customComments": true,
        "embedConsents": true,
        "pages": true,
        "postsPage": true
    },
    "menus": {
        "mainMenu": "Main menu",
        "footerMenu": "Footer menu"
    },
    "config": [
        {
            "name": "postsPerPage",
            "label": "Posts per page",
            "value": 5,
            "type": "number"
        },
        {
            "name": "tagsPostsPerPage",
            "label": "Tags posts per page",
            "value": 5,
            "type": "number"
        },
        {
            "name": "authorsPostsPerPage",
            "label": "Authors posts per page",
            "value": 5,
            "type": "number"
        },
        {
            "name": "excerptLength",
            "label": "Excerpt length",
            "value": 25,
            "type": "number"
        },
        {
            "name": "logo",
            "label": "Website logo",
            "value": "",
            "type": "upload",
            "upload": true
        }
    ],
    "customConfig": [
        {
            "name": "showIntroText",
            "label": "Show intro text",
            "group": "General",
            "value": true,
            "type": "checkbox"
        },
        {
            "name": "introText",
            "label": "Intro text",
            "group": "General",
            "value": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Fusce tempus dolor sed eros vestibulum sollicitudin. Praesent mollis a nulla sed dapibus. Donec placerat ante in venenatis facilisis. Nulla consequat molestie nunc, ut pharetra purus blandit a. Aliquam suscipit egestas nunc, ac tempor purus fermentum a.",
            "type": "wysiwyg"
        },
        {
            "name": "showPostsListIndex",
            "label": "Show posts list on index",
            "group": "General",
            "value": true,
            "type": "checkbox"
        },
        {
            "name": "separator",
            "type": "separator",
            "label": "Favicon",
            "group": "General",
            "size": "small"
        },
        {
            "name": "faviconUpload",
            "label": "Upload favicon file",
            "group": "General",
            "note": "The ideal size of a favicon is 16x16 pixels. Save your favicon as either favicon.png or favicon.ico",
            "value": "",
            "type": "smallupload",
            "upload": true
        },
        {
            "name": "faviconExtension",
            "label": "Favicon extension",
            "group": "General",
            "value": "image/x-icon",
            "type": "select",
            "options": [
                {
                    "label": ".ico",
                    "value": "image/x-icon"
                },
                {
                    "label": ".png",
                    "value": "image/png"
                }
            ]
        },
        {
            "name": "rowSectionBorder",
            "label": "Show Row Sections border",
            "group": "Layout",
            "value": true,
            "type": "checkbox"
        },
        {
            "name": "fontSize",
            "label": "Font size",
            "group": "Fonts",
            "note": "The font-size of the text paragraphs",
            "value": "16",
            "type": "range",
            "min": 12,
            "max": 20,
            "step": 1
        },
        {
            "name": "footerLogos",
            "label": "Footer Ally Logos",
            "group": "Footer Settings",
            "note": "Add logos for project allies. They will automatically size themselves to fit the layout.",
            "type": "repeater",
            "value": [],
            "maxCount": -1,
            "hasEmptyState": true,
            "translations": {
                "addItem": "Add New Logo",
                "emptyState": "No logos added yet. Click the button to add your first ally.",
                "removeItem": "Remove"
            },
            "structure": [
                {
                "name": "logoImage",
                "label": "Upload Logo",
                "type": "upload",
                "width": 50
                },
                {
                "name": "logoLink",
                "label": "Website Link (Optional)",
                "type": "text",
                "placeholder": "https://...",
                "width": 50
                }
            ]
        }
    ],
    "authorConfig": [
        {
            "name": "displayPostCounter",
            "label": "Display post counter",
            "value": 1,
            "type": "select",
            "options": [
                {
                    "label": "Enabled",
                    "value": 1
                },
                {
                    "label": "Disabled",
                    "value": 0
